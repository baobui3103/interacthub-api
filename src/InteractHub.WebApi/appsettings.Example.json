{
    "ConnectionStrings": {
        "InteractHubDatabase": "Host=localhost;Port=5432;Database=InteractHubDb;Username=postgres;Password=<your-password>"
    },
    "AllowedOrigins": [
        "https://localhost:5173",
        "https://localhost:3000"
    ],
